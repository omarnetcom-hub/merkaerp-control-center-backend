# Odoo 19.0 Implementation for Caja Simple
# Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=8787
HOST=localhost

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/cajasimple
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cajasimple
DB_USER=postgres
DB_PASSWORD=password

# SQLite fallback (optional, for local development)
SQLITE_DB=./data/cajasimple.db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# CORS Configuration
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# API Configuration
API_PREFIX=/api
API_VERSION=v1

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Payment Gateway Configuration (for Phase 4)
STRIPE_SECRET_KEY=sk_test_your_key_here
PAYPAL_CLIENT_ID=your_paypal_id_here

# AWS/Cloud Storage (for Phase 4)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_BUCKET_NAME=your-bucket-name

# Feature Flags
ENABLE_POS=false
ENABLE_HR=false
ENABLE_CRM=false
ENABLE_MANUFACTURING=false

# Localization
DEFAULT_TIMEZONE=America/New_York
DEFAULT_CURRENCY=USD
DEFAULT_LANGUAGE=en
